<div class="space-y-8 w-full">
  <!-- Header Card -->
  <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-6 md:p-8 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div class="space-y-2">
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <%= link_to "Projects", root_path, class: "hover:text-indigo-600 font-medium" %>
        <span>/</span>
        <%= link_to @project.name, project_path(@project, tab: "prompts"), class: "hover:text-indigo-600 font-medium" %>
        <span>/</span>
        <span class="font-semibold text-slate-600 dark:text-slate-200"><%= @prompt.name %></span>
      </div>
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight"><%= @prompt.name %></h1>
        <% if @prompt.latest_version.present? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 text-xs font-bold border border-indigo-100/50 dark:border-indigo-900/30">
            Latest V<%= @prompt.latest_version.version_number %>
          </span>
        <% end %>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed max-w-2xl">
        <%= @prompt.description.presence || "No description provided." %>
      </p>
    </div>

    <div class="flex items-center gap-2 self-start md:self-center shrink-0">
      <%= link_to edit_project_prompt_path(@project, @prompt), class: "inline-flex items-center gap-1.5 px-4 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-xs font-bold text-white shadow-md shadow-indigo-500/10 hover:shadow-indigo-500/20 transition cursor-pointer" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
        </svg>
        New Version
      <% end %>

      <%= button_to project_prompt_path(@project, @prompt), method: :delete, data: { confirm: "Are you sure? This will delete all history." }, 
          class: "inline-flex items-center gap-1.5 px-4 py-2.5 rounded-xl bg-rose-50 hover:bg-rose-100 dark:bg-rose-950/20 dark:hover:bg-rose-950/40 text-xs font-bold text-rose-600 dark:text-rose-400 border border-rose-100 dark:border-rose-900 cursor-pointer" do %>
        Delete Prompt
      <% end %>
    </div>
  </div>

  <!-- Version Grid / History Timeline -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Timeline Navigation -->
    <div class="lg:col-span-1 space-y-6">
      <div class="border-b border-slate-200/60 dark:border-slate-800/60 pb-3">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Version History</h2>
        <p class="text-xs text-slate-400">Chronological stack of prompt configurations</p>
      </div>

      <div class="space-y-4">
        <% @versions.each_with_index do |v, idx| %>
          <a href="#version-<%= v.id %>" class="block group bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 hover:border-slate-300 dark:hover:border-slate-700 p-4 rounded-2xl shadow-sm transition">
            <div class="flex items-start justify-between gap-4">
              <div class="space-y-1">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 text-[10px] font-bold">
                  Version <%= v.version_number %>
                </span>
                <h4 class="text-xs font-bold text-slate-700 dark:text-slate-200 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                  <%= v.description.presence || "No release notes provided." %>
                </h4>
                <p class="text-[10px] text-slate-400 font-light"><%= v.created_at.strftime("%b %d, %Y at %I:%M %p") %></p>
              </div>
              <% if idx == 0 %>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400 text-[9px] font-extrabold uppercase tracking-wider shrink-0">Active</span>
              <% end %>
            </div>
          </a>
        <% end %>
      </div>
    </div>

    <!-- Configuration Display -->
    <div class="lg:col-span-2 space-y-8">
      <div class="border-b border-slate-200/60 dark:border-slate-800/60 pb-3">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Prompt Template Details</h2>
        <p class="text-xs text-slate-400">Details, parameters, and prompt bodies per version</p>
      </div>

      <div class="space-y-8">
        <% @versions.each do |v| %>
          <div id="version-<%= v.id %>" class="scroll-mt-20 bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-6 shadow-sm space-y-6">
            <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800/80 pb-4">
              <div class="space-y-1">
                <div class="flex items-center gap-2">
                  <span class="text-lg font-extrabold text-slate-900 dark:text-white">Version V<%= v.version_number %></span>
                  <span class="text-xs text-slate-400 font-light">• <%= v.created_at.strftime("%B %d, %Y") %></span>
                </div>
                <p class="text-xs text-slate-500 dark:text-slate-400">Release Notes: <strong class="font-medium text-slate-700 dark:text-slate-200"><%= v.description.presence || "None" %></strong></p>
              </div>
            </div>

            <!-- System Prompt Box -->
            <div class="space-y-2">
              <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">System Prompt</span>
              <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 rounded-2xl p-4 font-mono text-xs text-slate-600 dark:text-slate-300 leading-relaxed whitespace-pre-wrap"><%= v.system_prompt %></div>
            </div>

            <!-- User Prompt Box -->
            <div class="space-y-2">
              <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">User Prompt Template</span>
              <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 rounded-2xl p-4 font-mono text-xs text-slate-600 dark:text-slate-300 leading-relaxed whitespace-pre-wrap"><%= v.user_prompt_template %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
