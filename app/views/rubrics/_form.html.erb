<%= form_with model: [project, rubric], local: true, class: "space-y-6" do |f| %>
  <% if rubric.errors.any? %>
    <div class="p-4 bg-rose-50 dark:bg-rose-950/30 border border-rose-100 dark:border-rose-900 rounded-xl text-rose-600 dark:text-rose-400 text-sm">
      <p class="font-semibold mb-1">Please fix the following errors:</p>
      <ul class="list-disc pl-4 space-y-1">
        <% rubric.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Rubric Metadata -->
  <div class="space-y-4">
    <div>
      <%= f.label :name, "Rubric Name", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_field :name, required: true, placeholder: "e.g. Tone Quality, Sentiment Consistency", 
          class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
    </div>

    <div>
      <%= f.label :description, "Rubric Description", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_area :description, rows: 2, placeholder: "Describe what this evaluation rubric guarantees...", 
          class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
    </div>
  </div>

  <!-- Dynamic Criteria (Stimulus Controller) -->
  <div data-controller="criteria" class="space-y-4 pt-6 border-t border-slate-100 dark:border-slate-800">
    <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-2">
      <h3 class="text-sm font-bold uppercase text-slate-400 tracking-wider">Rubric Criteria</h3>
      <button type="button" data-action="click->criteria#addRow" class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Criterion
      </button>
    </div>

    <p class="text-xs text-slate-400">Add weighting criteria. Weight determines the impact of each criterion in the overall calculation.</p>

    <!-- Container for dynamic criteria rows -->
    <div data-criteria-target="container" class="space-y-4">
      <% rubric.rubric_criteria.each do |crit| %>
        <div class="bg-slate-50 dark:bg-slate-800/40 p-4 rounded-2xl border border-slate-200/50 dark:border-slate-700/50 space-y-3 relative criterion-row">
          <button type="button" data-action="click->criteria#removeRow" class="absolute top-4 right-4 text-slate-400 hover:text-rose-500 transition cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
          </button>

          <div class="grid grid-cols-3 gap-4">
            <div class="col-span-2">
              <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1">Criterion Name</label>
              <input type="text" name="criteria[][name]" value="<%= crit.name %>" required placeholder="e.g. Empathy, Boundaries" 
                  class="block w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs" />
            </div>

            <div>
              <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1">Weight</label>
              <input type="number" name="criteria[][weight]" value="<%= crit.weight %>" required min="1" max="10" 
                  class="block w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs font-bold text-center" />
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1">Description</label>
            <textarea name="criteria[][description]" rows="2" placeholder="Describe the grading standard..." 
                class="block w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs"><%= crit.description %></textarea>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Template for new criteria -->
    <template data-criteria-target="template">
      <div class="bg-slate-50 dark:bg-slate-800/40 p-4 rounded-2xl border border-slate-200/50 dark:border-slate-700/50 space-y-3 relative criterion-row animate-fadeIn">
        <button type="button" data-action="click->criteria#removeRow" class="absolute top-4 right-4 text-slate-400 hover:text-rose-500 transition cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </button>

        <div class="grid grid-cols-3 gap-4">
          <div class="col-span-2">
            <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1">Criterion Name</label>
            <input type="text" name="criteria[][name]" required placeholder="e.g. Empathy, Boundaries" 
                class="block w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs" />
          </div>

          <div>
            <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1">Weight</label>
            <input type="number" name="criteria[][weight]" value="1" required min="1" max="10" 
                class="block w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs font-bold text-center" />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1">Description</label>
          <textarea name="criteria[][description]" rows="2" placeholder="Describe the grading standard..." 
              class="block w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs"></textarea>
        </div>
      </div>
    </template>

  </div>

  <div class="flex items-center gap-3 pt-6 border-t border-slate-100 dark:border-slate-800">
    <%= f.submit rubric.new_record? ? "Create Rubric" : "Save Changes", 
        class: "py-3 px-5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-bold shadow-lg hover:shadow-indigo-500/25 transition duration-200 cursor-pointer text-sm" %>
    <%= link_to "Cancel", project_path(project, tab: "rubrics"), 
        class: "py-3 px-5 bg-slate-100 hover:bg-slate-200 text-slate-700 dark:bg-slate-800 dark:hover:bg-slate-700 dark:text-slate-300 rounded-xl font-semibold transition text-sm cursor-pointer" %>
  </div>
<% end %>
