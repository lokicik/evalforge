<!DOCTYPE html>
<html class="h-full bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100">
  <head>
    <title><%= content_for(:title) || "EvalForge - AI Prompt Evaluation & Versioning Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
    </style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full flex flex-col font-sans antialiased selection:bg-indigo-500 selection:text-white">
    <!-- Sleek Top Glassmorphic Navigation -->
    <header class="sticky top-0 z-40 w-full border-b border-slate-200/80 bg-white/80 backdrop-blur-md dark:border-slate-800/80 dark:bg-slate-950/80">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center gap-8">
            <%= link_to root_path, class: "flex items-center gap-2.5 group" do %>
              <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 text-white shadow-md shadow-indigo-500/20 group-hover:scale-105 transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
              </div>
              <span class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-slate-900 via-indigo-950 to-purple-950 bg-clip-text text-transparent dark:from-white dark:via-slate-200 dark:to-slate-400">
                Eval<span class="text-indigo-600 dark:text-indigo-400">Forge</span>
              </span>
            <% end %>

            <% if authenticated? %>
              <nav class="hidden md:flex items-center gap-1">
                <%= link_to root_path, class: "px-3 py-2 text-sm font-semibold rounded-lg transition #{controller_name == 'projects' ? 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/40 dark:text-indigo-400' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 dark:text-slate-400 dark:hover:text-white dark:hover:bg-slate-900'}" do %>
                  Projects
                <% end %>

                <%= link_to review_queue_projects_path, class: "px-3 py-2 text-sm font-semibold rounded-lg transition flex items-center gap-1.5 #{action_name == 'review_queue' ? 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/40 dark:text-indigo-400' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 dark:text-slate-400 dark:hover:text-white dark:hover:bg-slate-900'}" do %>
                  Review Queue
                  <% pending_count = ModelResponse.pending_review_for_user(Current.user).count %>
                  <% if pending_count > 0 %>
                    <span class="inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold rounded-full bg-rose-500 text-white animate-pulse">
                      <%= pending_count %>
                    </span>
                  <% end %>
                <% end %>
              </nav>
            <% end %>
          </div>

          <div class="flex items-center gap-4">
            <% if authenticated? %>
              <div class="hidden sm:flex items-center gap-2 border-r border-slate-200 dark:border-slate-800 pr-4 mr-1">
                <div class="flex h-7 w-7 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 text-xs font-bold text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-950">
                  <%= Current.user.email_address[0].upcase %>
                </div>
                <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 max-w-[120px] truncate">
                  <%= Current.user.email_address %>
                </span>
              </div>

              <%= button_to session_path, method: :delete, class: "inline-flex items-center justify-center rounded-xl bg-slate-100 hover:bg-rose-50 text-slate-700 hover:text-rose-600 dark:bg-slate-900 dark:hover:bg-rose-950/30 dark:text-slate-300 dark:hover:text-rose-400 px-3.5 py-2 text-sm font-semibold transition cursor-pointer border border-slate-200/50 dark:border-slate-800/50" do %>
                <span>Sign Out</span>
              <% end %>
            <% else %>
              <%= link_to "Sign In", new_session_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white px-3 py-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-900" %>
              <%= link_to "Sign Up", new_user_registration_path, class: "rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white px-3.5 py-2 text-sm font-semibold shadow-md shadow-indigo-500/10 hover:shadow-indigo-500/20 transition cursor-pointer" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <!-- Content Container -->
    <main class="flex-grow mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <% if notice %>
        <div class="mb-6 p-4 bg-emerald-50 dark:bg-emerald-950/20 border border-emerald-100 dark:border-emerald-900 rounded-2xl text-emerald-700 dark:text-emerald-400 text-sm font-medium flex items-center gap-2">
          <svg class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-6 p-4 bg-rose-50 dark:bg-rose-950/20 border border-rose-100 dark:border-rose-900 rounded-2xl text-rose-700 dark:text-rose-400 text-sm font-medium flex items-center gap-2">
          <svg class="h-5 w-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200/60 dark:border-slate-800/60 py-6 bg-slate-50 dark:bg-slate-950">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="text-xs text-slate-400">
          &copy; <%= Time.current.year %> EvalForge. Built for professional prompt engineering operations.
        </span>
        <span class="text-xs text-slate-400 flex items-center gap-1">
          Made with Rails 8 & ❤️
        </span>
      </div>
    </footer>
  </body>
</html>
