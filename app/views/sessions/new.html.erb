<div class="min-h-[80vh] flex flex-col justify-center items-center px-4">
  <div class="w-full max-w-md bg-white dark:bg-slate-900 shadow-2xl rounded-2xl border border-slate-100 dark:border-slate-800 p-8 relative overflow-hidden transition-all duration-300">
    <!-- Premium Accent Gradient Bar -->
    <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>

    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
      </div>
      <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Welcome back</h2>
      <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
        Sign in to manage and evaluate your prompts.
      </p>
    </div>

    <%= form_with url: session_url, local: true, class: "space-y-6" do |f| %>
      <% if alert = flash[:alert] %>
        <div class="p-4 bg-rose-50 dark:bg-rose-950/30 border border-rose-100 dark:border-rose-900 rounded-xl text-rose-600 dark:text-rose-400 text-sm">
          <%= alert %>
        </div>
      <% end %>

      <% if notice = flash[:notice] %>
        <div class="p-4 bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-100 dark:border-emerald-900 rounded-xl text-emerald-600 dark:text-emerald-400 text-sm">
          <%= notice %>
        </div>
      <% end %>

      <div>
        <%= f.label :email_address, "Email Address", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email", 
            placeholder: "you@example.com", value: params[:email_address],
            class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
      </div>

      <div>
        <div class="flex justify-between items-center mb-1">
          <%= f.label :password, "Password", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300" %>
          <%= link_to "Forgot?", new_password_path, class: "text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500" %>
        </div>
        <%= f.password_field :password, required: true, autocomplete: "current-password", 
            placeholder: "••••••••", 
            class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
      </div>

      <%= f.submit "Sign In", 
          class: "w-full py-3 px-4 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white rounded-xl font-semibold shadow-lg hover:shadow-indigo-500/25 transition duration-200 cursor-pointer text-center text-sm" %>

      <div class="text-center text-sm text-slate-500 dark:text-slate-400 pt-2 border-t border-slate-100 dark:border-slate-800">
        Don't have an account? 
        <%= link_to "Sign Up", new_user_registration_path, class: "font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500" %>
      </div>
    <% end %>
  </div>
</div>
