<div class="space-y-8 w-full">
  <!-- Dynamic Hero Header -->
  <div class="relative rounded-3xl bg-slate-900 text-white p-8 md:p-12 overflow-hidden shadow-2xl">
    <div class="absolute inset-0 bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500 opacity-90"></div>
    <div class="absolute -right-10 -bottom-10 w-60 h-60 bg-white/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-2xl space-y-4">
      <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-white/10 text-white text-xs font-semibold backdrop-blur-md">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> Live Workspace
      </span>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">
        Master Your LLM Prompts
      </h1>
      <p class="text-indigo-100 text-base md:text-lg font-light leading-relaxed">
        EvalForge lets you version prompts, manage complex test cases, score outputs against weighted rubrics, and run comprehensive human and automated reviews.
      </p>
      <div class="pt-2">
        <%= link_to new_project_path, class: "inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-white text-slate-900 font-bold hover:bg-slate-50 transition shadow-lg shadow-black/10 text-sm cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-indigo-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Create New Project
        <% end %>
      </div>
    </div>
  </div>

  <!-- Projects Grid -->
  <div class="space-y-6">
    <div class="flex items-center justify-between border-b border-slate-200/60 dark:border-slate-800/60 pb-4">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Your Projects</h2>
        <p class="text-xs text-slate-400">Manage prompting targets, datasets, and evaluations</p>
      </div>
    </div>

    <%= form_with url: projects_path, method: :get, local: true, class: "flex items-center gap-3 flex-wrap" do %>
      <%= text_field_tag :project_query, @project_query, placeholder: "Search projects", class: "w-full md:w-96 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 placeholder:text-slate-400 focus:border-indigo-500 focus:ring-0" %>
      <%= submit_tag "Search", class: "px-4 py-2.5 rounded-xl bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition cursor-pointer" %>
      <% if @project_query.present? %>
        <%= link_to "Clear", projects_path, class: "text-xs font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" %>
      <% end %>
    <% end %>

    <% if @projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @projects.each do |project| %>
          <div class="group bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/50 dark:border-slate-800/50 p-6 shadow-md hover:shadow-xl dark:hover:shadow-indigo-500/5 hover:border-slate-300 dark:hover:border-slate-700 transition duration-300 relative flex flex-col justify-between">
            <div class="space-y-3">
              <div class="flex items-start justify-between">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                  <%= link_to project.name, project %>
                </h3>
              </div>
              <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">
                <%= project.description.presence || "No description provided." %>
              </p>
            </div>

            <!-- Stats Bar -->
            <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-800/80 flex items-center justify-between text-xs text-slate-400">
              <div class="flex items-center gap-4">
                <span class="flex items-center gap-1">
                  <strong class="font-bold text-slate-700 dark:text-slate-200"><%= project.prompts.count %></strong> Prompts
                </span>
                <span class="flex items-center gap-1">
                  <strong class="font-bold text-slate-700 dark:text-slate-200"><%= project.test_cases.count %></strong> Cases
                </span>
                <span class="flex items-center gap-1">
                  <strong class="font-bold text-slate-700 dark:text-slate-200"><%= project.evaluation_runs.count %></strong> Runs
                </span>
              </div>
              <span class="text-[10px] bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-300 px-2 py-0.5 rounded-full font-medium">
                Active
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-16 bg-white dark:bg-slate-900 rounded-3xl border border-dashed border-slate-300 dark:border-slate-800 p-8 shadow-inner">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 0 1 2.008 1.24l.885 1.77a2.25 2.25 0 0 0 2.007 1.24h1.98a2.25 2.25 0 0 0 2.007-1.24l.885-1.77a2.25 2.25 0 0 1 2.007-1.24h3.86m-18 0h18" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">No projects yet</h3>
        <p class="text-slate-500 dark:text-slate-400 max-w-sm mx-auto mb-6 text-sm">
          Get started by creating your first project workspace. You can then add prompts, configure rubrics, and run evaluations.
        </p>
        <div class="max-w-2xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-3 text-left mb-6">
          <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/30 p-4">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Path 1</p>
            <p class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">Create a blank project</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Best if you want to build the workflow yourself from scratch.</p>
          </div>
          <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/30 p-4">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Path 2</p>
            <p class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">Load the demo dataset</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><code>bin\rails db:seed</code> gives you a portfolio-ready benchmark story immediately.</p>
          </div>
          <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/30 p-4">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Path 3</p>
            <p class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">Read the docs first</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">See the architecture and demo guide in the repo if you want the big picture before clicking around.</p>
          </div>
        </div>
        <%= link_to new_project_path, class: "inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-bold transition shadow-lg shadow-indigo-500/25 text-sm cursor-pointer" do %>
          Create Your First Project
        <% end %>
      </div>
    <% end %>
  </div>
</div>
