<div class="space-y-6 w-full">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Human Review Queue</h1>
    <p class="text-sm text-slate-500 dark:text-slate-400">
      Model responses that are ready for qualitative grading and human alignment reviews.
    </p>
  </div>

  <% if @model_responses.any? %>
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-800">
          <thead class="bg-slate-50 dark:bg-slate-900/60">
            <tr>
              <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Project / Run</th>
              <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Test Case Input</th>
              <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Model Response</th>
              <th scope="col" class="relative px-6 py-3.5"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800 bg-white dark:bg-slate-900">
            <% @model_responses.each do |resp| %>
              <% project = resp.evaluation_run.project %>
              <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition">
                <td class="px-6 py-4">
                  <div class="space-y-1">
                    <span class="text-xs font-bold text-slate-700 dark:text-slate-200 block truncate max-w-[150px]"><%= project.name %></span>
                    <span class="text-[10px] text-slate-400 block truncate max-w-[150px]"><%= resp.evaluation_run.name %></span>
                    <span class="inline-flex px-1.5 py-0.5 rounded bg-indigo-50 dark:bg-indigo-950/40 text-[9px] font-bold text-indigo-600 dark:text-indigo-400">
                      V<%= resp.evaluation_run.prompt_version.version_number %>
                    </span>
                  </div>
                </td>
                
                <td class="px-6 py-4 max-w-xs">
                  <div class="space-y-1 text-xs">
                    <% resp.test_case.input_variables.each do |key, val| %>
                      <div>
                        <span class="font-mono bg-slate-100 dark:bg-slate-800 px-1 py-0.2 rounded text-[10px]"><%= key %></span>:
                        <span class="text-slate-500 dark:text-slate-400 truncate max-w-[180px] inline-block align-middle"><%= val %></span>
                      </div>
                    <% end %>
                    <p class="text-[11px] text-slate-400 line-clamp-1 italic mt-1">Expected: <%= resp.test_case.expected_behavior %></p>
                  </div>
                </td>

                <td class="px-6 py-4 max-w-sm">
                  <p class="text-xs text-slate-600 dark:text-slate-300 font-mono line-clamp-2 bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 p-2.5 rounded-xl"><%= resp.raw_response.presence || "No response content." %></p>
                </td>

                <td class="px-6 py-4 text-right text-xs font-medium">
                  <%= link_to new_project_model_response_review_path(project, resp, return_to: review_queue_projects_path), 
                      class: "inline-flex items-center gap-1.5 px-3 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-bold rounded-xl shadow-md shadow-indigo-500/10 hover:shadow-indigo-500/20 transition cursor-pointer" do %>
                    Grade Output
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white dark:bg-slate-900 rounded-3xl border border-dashed border-slate-300 dark:border-slate-800 p-8 shadow-inner">
      <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Queue is clear!</h3>
      <p class="text-slate-500 dark:text-slate-400 max-w-sm mx-auto text-sm">
        All generated model responses have been successfully reviewed and scored. Run new evaluation sessions to generate more outputs.
      </p>
    </div>
  <% end %>
</div>
