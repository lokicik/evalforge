<div class="max-w-xl mx-auto py-8">
  <div class="bg-white dark:bg-slate-900 shadow-2xl rounded-2xl border border-slate-100 dark:border-slate-800 p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-indigo-500 to-purple-500"></div>

    <div class="mb-8">
      <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Create new project</h2>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
        A project groups all prompts, version histories, test cases, and evaluation runs.
      </p>
    </div>

    <%= render "form", project: @project %>
  </div>
</div>
