<div class="space-y-8 w-full max-w-7xl mx-auto py-4">
  <!-- Nav header -->
  <div class="flex items-center justify-between gap-6 flex-wrap">
    <div class="space-y-2">
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <%= link_to "Projects", root_path, class: "hover:text-indigo-600 font-medium" %>
        <span>/</span>
        <%= link_to @project.name, project_path(@project), class: "hover:text-indigo-600 font-medium" %>
        <span>/</span>
        <span class="font-semibold text-slate-600 dark:text-slate-200">Analytics</span>
      </div>
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Project Analytics</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400">
        Track run performance over time, compare prompt versions, and identify where failures cluster.
      </p>
    </div>

    <%= form_with url: project_comparison_dashboard_path(@project), method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-3 w-full lg:w-auto" do %>
      <%= select_tag :prompt_id, options_for_select([["All prompts", ""]] + @prompts.map { |prompt| [prompt.name, prompt.id] }, @selected_prompt&.id), class: "rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 focus:border-indigo-500 focus:ring-0" %>
      <%= select_tag :run_model, options_for_select([["All models", ""]] + @run_model_options.map { |model| [model, model] }, @run_model), class: "rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 focus:border-indigo-500 focus:ring-0" %>
      <%= date_field_tag :run_from, @run_from&.iso8601, class: "rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 focus:border-indigo-500 focus:ring-0" %>
      <%= date_field_tag :run_to, @run_to&.iso8601, class: "rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 focus:border-indigo-500 focus:ring-0" %>
      <div class="md:col-span-4 flex items-center gap-3">
        <%= submit_tag "Apply Filters", class: "px-4 py-2.5 rounded-xl bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition cursor-pointer" %>
        <% if @selected_prompt.present? || @run_model.present? || @run_from.present? || @run_to.present? %>
          <%= link_to "Clear", project_comparison_dashboard_path(@project), class: "text-xs font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Runs In Scope</span>
      <div class="text-3xl font-extrabold text-slate-900 dark:text-white"><%= @summary_metrics[:total_runs] %></div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Reviewed Responses</span>
      <div class="text-3xl font-extrabold text-slate-900 dark:text-white"><%= @summary_metrics[:reviewed_responses] %></div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Average Score</span>
      <div class="text-3xl font-extrabold text-indigo-600 dark:text-indigo-400"><%= @summary_metrics[:average_score] %>%</div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Average Pass Rate</span>
      <div class="text-3xl font-extrabold text-emerald-600 dark:text-emerald-400"><%= @summary_metrics[:average_pass_rate] %>%</div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Total Tokens</span>
      <div class="text-2xl font-extrabold text-slate-900 dark:text-white"><%= number_with_delimiter(@summary_metrics[:total_tokens_used]) %></div>
    </div>
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Total Cost</span>
      <div class="text-2xl font-extrabold text-slate-900 dark:text-white">$<%= format("%.6f", @summary_metrics[:total_cost]) %></div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-6 shadow-sm space-y-4">
    <div class="border-b border-slate-100 dark:border-slate-800 pb-3">
      <h2 class="text-lg font-bold text-slate-900 dark:text-white">Cross-Run Trends</h2>
      <p class="text-xs text-slate-400">Project-level performance and cost movement across the filtered run set.</p>
    </div>

    <% if @trend_rows.any? %>
      <% max_score = [@trend_rows.map { |row| row[:average_score] }.max.to_f, 1.0].max %>
      <% max_cost = [@trend_rows.map { |row| row[:total_cost].to_f }.max.to_f, 0.000001].max %>
      <% max_tokens = [@trend_rows.map { |row| row[:total_tokens_used] }.max.to_i, 1].max %>
      <div class="space-y-3">
        <% @trend_rows.each do |row| %>
          <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/30 p-4">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sm font-bold text-slate-900 dark:text-white"><%= row[:run].name %></p>
                <p class="text-[11px] text-slate-400"><%= row[:run].created_at.strftime("%b %d, %Y %H:%M") %> · <%= row[:run].llm_model %> · <%= row[:run].prompt_version.prompt.name %></p>
              </div>
              <%= link_to "Open Run", project_evaluation_run_path(@project, row[:run]), class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-700 text-xs font-bold text-slate-700 dark:text-slate-300 transition" %>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-5 gap-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Score</p>
                <p class="mt-1 text-sm font-extrabold text-indigo-600 dark:text-indigo-400"><%= row[:average_score] %>%</p>
                <div class="mt-2 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-indigo-500" style="width: <%= ((row[:average_score] / max_score) * 100).round(1) %>%"></div>
                </div>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Pass Rate</p>
                <p class="mt-1 text-sm font-extrabold text-emerald-600 dark:text-emerald-400"><%= row[:pass_rate] %>%</p>
                <div class="mt-2 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-emerald-500" style="width: <%= row[:pass_rate] %>%"></div>
                </div>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Cost</p>
                <p class="mt-1 text-sm font-extrabold text-slate-900 dark:text-white">$<%= format("%.6f", row[:total_cost]) %></p>
                <div class="mt-2 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-slate-900 dark:bg-slate-200" style="width: <%= ((row[:total_cost].to_f / max_cost) * 100).round(1) %>%"></div>
                </div>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Tokens</p>
                <p class="mt-1 text-sm font-extrabold text-slate-900 dark:text-white"><%= number_with_delimiter(row[:total_tokens_used]) %></p>
                <div class="mt-2 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-amber-500" style="width: <%= ((row[:total_tokens_used].to_f / max_tokens) * 100).round(1) %>%"></div>
                </div>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Failures</p>
                <p class="mt-1 text-sm font-extrabold text-rose-500"><%= row[:failures] %></p>
                <p class="mt-2 text-[11px] text-slate-400"><%= row[:reviewed_cases] %> reviewed responses</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-slate-500 dark:text-slate-400">No runs match the current filter scope.</p>
    <% end %>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-6 shadow-sm space-y-4">
      <div class="border-b border-slate-100 dark:border-slate-800 pb-3">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Top Failed Criteria</h2>
        <p class="text-xs text-slate-400">Recurring rubric weaknesses across failed reviewed responses.</p>
      </div>
      <% if @criterion_failure_aggregates.any? %>
        <div class="space-y-3">
          <% @criterion_failure_aggregates.each do |entry| %>
            <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/30 p-4">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-bold text-slate-900 dark:text-white"><%= entry[:criterion].name %></p>
                  <p class="text-[11px] text-slate-400"><%= entry[:criterion].description %></p>
                </div>
                <div class="text-right">
                  <p class="text-lg font-extrabold text-rose-500"><%= entry[:failures] %></p>
                  <p class="text-[10px] uppercase tracking-wider text-slate-400 font-bold">failures</p>
                </div>
              </div>
              <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">Average failing score: <span class="font-bold text-slate-700 dark:text-slate-200"><%= entry[:average_score] %> / 5</span></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500 dark:text-slate-400">No failed reviewed criteria are in the current scope.</p>
      <% end %>
    </div>

    <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl p-6 shadow-sm space-y-4">
      <div class="border-b border-slate-100 dark:border-slate-800 pb-3">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Weakest Test Cases</h2>
        <p class="text-xs text-slate-400">Test cases with the worst repeated outcomes across reviewed responses.</p>
      </div>
      <% if @weakest_test_cases.any? %>
        <div class="space-y-3">
          <% @weakest_test_cases.each do |entry| %>
            <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/30 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-bold text-slate-900 dark:text-white">Test Case #<%= entry[:test_case].id %></p>
                  <p class="text-[11px] text-slate-400"><%= entry[:test_case].difficulty %> · <%= entry[:test_case].tags.presence || "No tags" %></p>
                </div>
                <div class="text-right">
                  <p class="text-lg font-extrabold text-rose-500"><%= entry[:failure_rate] %>%</p>
                  <p class="text-[10px] uppercase tracking-wider text-slate-400 font-bold">failure rate</p>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-3 text-xs text-slate-500 dark:text-slate-400">
                <div>
                  <p class="font-semibold text-slate-700 dark:text-slate-200">Reviewed</p>
                  <p><%= entry[:reviewed_count] %></p>
                </div>
                <div>
                  <p class="font-semibold text-slate-700 dark:text-slate-200">Failed</p>
                  <p><%= entry[:failed_count] %></p>
                </div>
                <div>
                  <p class="font-semibold text-slate-700 dark:text-slate-200">Avg score</p>
                  <p><%= entry[:average_score] %>%</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500 dark:text-slate-400">No reviewed test cases are in the current scope.</p>
      <% end %>
    </div>
  </div>

  <!-- Comparison Matrix Table -->
  <div class="space-y-4">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Prompt Version Comparison</h2>
        <p class="text-xs text-slate-400">Select a prompt above to compare its version performance inside the active analytics scope.</p>
      </div>
    </div>

    <% if @selected_prompt && @comparison_data.any? %>
      <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 rounded-3xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-800">
            <thead class="bg-slate-50 dark:bg-slate-900/60">
              <tr>
                <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Prompt Version</th>
                <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Release Description</th>
                <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Avg Score</th>
                <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Pass Rate</th>
                <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Reviewed Cases</th>
                <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Failures</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800 bg-white dark:bg-slate-900">
              <% @comparison_data.each_with_index do |data, idx| %>
                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition">
                  <!-- Version badge -->
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-2">
                      <span class="inline-flex px-2.5 py-0.5 rounded-full bg-indigo-50 dark:bg-indigo-950/40 text-xs font-bold text-indigo-600 dark:text-indigo-400">
                        V<%= data[:version].version_number %>
                      </span>
                      <% if idx == 0 %>
                        <span class="inline-flex px-1.5 py-0.5 rounded bg-emerald-50 dark:bg-emerald-950/30 text-[9px] font-extrabold uppercase tracking-wider text-emerald-600 dark:text-emerald-400 shrink-0">Latest</span>
                      <% end %>
                    </div>
                  </td>

                  <!-- Notes -->
                  <td class="px-6 py-4 max-w-xs text-xs text-slate-700 dark:text-slate-300 font-medium">
                    <%= data[:version].description %>
                  </td>

                  <!-- Avg Score -->
                  <td class="px-6 py-4">
                    <div class="space-y-1 max-w-[120px]">
                      <div class="text-sm font-extrabold text-indigo-600 dark:text-indigo-400"><%= data[:avg_score] %>%</div>
                      <!-- Tiny visual progress bar -->
                      <div class="w-full h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width: <%= data[:avg_score] %>%"></div>
                      </div>
                    </div>
                  </td>

                  <!-- Pass Rate -->
                  <td class="px-6 py-4">
                    <div class="space-y-1 max-w-[120px]">
                      <div class="text-sm font-extrabold text-emerald-600 dark:text-emerald-400"><%= data[:pass_rate] %>%</div>
                      <!-- Tiny visual progress bar -->
                      <div class="w-full h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full bg-emerald-500 rounded-full" style="width: <%= data[:pass_rate] %>%"></div>
                      </div>
                    </div>
                  </td>

                  <!-- Reviewed Cases -->
                  <td class="px-6 py-4 text-xs font-bold text-slate-700 dark:text-slate-200">
                    <%= data[:reviewed_cases] %>
                  </td>

                  <!-- Failures -->
                  <td class="px-6 py-4 text-xs font-bold <%= data[:failures] > 0 ? 'text-rose-500 font-extrabold' : 'text-slate-400' %>">
                    <%= data[:failures] %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% elsif @selected_prompt.present? %>
      <div class="text-center py-16 bg-white dark:bg-slate-900 rounded-3xl border border-dashed border-slate-300 dark:border-slate-800 p-8 shadow-inner">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">No comparison data</h3>
        <p class="text-slate-500 dark:text-slate-400 max-w-sm mx-auto text-sm">
          Create multiple versions of your prompts and run evaluation runs for them to see side-by-side performance comparisons.
        </p>
      </div>
    <% else %>
      <div class="text-center py-16 bg-white dark:bg-slate-900 rounded-3xl border border-dashed border-slate-300 dark:border-slate-800 p-8 shadow-inner">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Choose a prompt to compare versions</h3>
        <p class="text-slate-500 dark:text-slate-400 max-w-sm mx-auto text-sm">
          Project-level analytics can span every prompt, but version comparison requires one prompt family to be selected.
        </p>
      </div>
    <% end %>
  </div>
</div>
