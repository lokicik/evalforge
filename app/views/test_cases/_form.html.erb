<%= form_with model: [project, test_case], local: true, class: "space-y-6" do |f| %>
  <% if test_case.errors.any? %>
    <div class="p-4 bg-rose-50 dark:bg-rose-950/30 border border-rose-100 dark:border-rose-900 rounded-xl text-rose-600 dark:text-rose-400 text-sm">
      <p class="font-semibold mb-1">Please fix the following errors:</p>
      <ul class="list-disc pl-4 space-y-1">
        <% test_case.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Dynamic Variable Editor (Stimulus Controller) -->
  <div data-controller="variables" class="space-y-4">
    <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-2">
      <h3 class="text-sm font-bold uppercase text-slate-400 tracking-wider">Input Variables</h3>
      <button type="button" data-action="click->variables#addRow" class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Variable
      </button>
    </div>

    <p class="text-xs text-slate-400">These values will be interpolated into the prompt templates. Keys must match the template slots (e.g. <code>user_input</code>).</p>

    <!-- Container for dynamic rows -->
    <div data-variables-target="container" class="space-y-3">
      <% (test_case.input_variables || {}).each do |key, value| %>
        <div class="flex items-center gap-3 variable-row">
          <input type="text" name="input_keys[]" value="<%= key %>" required placeholder="Variable Key (e.g. user_input)" 
              class="block w-1/3 px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs font-mono" />
          
          <input type="text" name="input_values[]" value="<%= value %>" required placeholder="Value (e.g. Hello friend!)" 
              class="block w-2/3 px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs" />
          
          <button type="button" data-action="click->variables#removeRow" class="text-slate-400 hover:text-rose-500 transition cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
          </button>
        </div>
      <% end %>
    </div>

    <!-- Template for new rows -->
    <template data-variables-target="template">
      <div class="flex items-center gap-3 variable-row animate-fadeIn">
        <input type="text" name="input_keys[]" required placeholder="Variable Key (e.g. user_input)" 
            class="block w-1/3 px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs font-mono" />
        
        <input type="text" name="input_values[]" required placeholder="Value" 
            class="block w-2/3 px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs" />
        
        <button type="button" data-action="click->variables#removeRow" class="text-slate-400 hover:text-rose-500 transition cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </button>
      </div>
    </template>
  </div>

  <div class="space-y-4 pt-4 border-t border-slate-100 dark:border-slate-800">
    <h3 class="text-sm font-bold uppercase text-slate-400 tracking-wider">Evaluation & Notes</h3>

    <div>
      <%= f.label :expected_behavior, "Expected Behavior", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_area :expected_behavior, rows: 3, placeholder: "What is the model expected to output? (e.g. Respond with a comforting, non-prescriptive tone)", 
          class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :difficulty, "Difficulty Level", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.select :difficulty, [["Low", "low"], ["Medium", "medium"], ["High", "high"]], {}, 
            class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
      </div>

      <div>
        <%= f.label :tags, "Tags", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_field :tags, placeholder: "e.g., empathy, boundary, social (comma-separated)", 
            class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :notes, "Notes / Context", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_area :notes, rows: 2, placeholder: "Any extra engineering or testing notes...", 
          class: "block w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition duration-200 text-sm" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-6 border-t border-slate-100 dark:border-slate-800">
    <%= f.submit test_case.new_record? ? "Create Test Case" : "Save Changes", 
        class: "py-3 px-5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-bold shadow-lg hover:shadow-indigo-500/25 transition duration-200 cursor-pointer text-sm" %>
    <%= link_to "Cancel", project_path(project, tab: "test_cases"), 
        class: "py-3 px-5 bg-slate-100 hover:bg-slate-200 text-slate-700 dark:bg-slate-800 dark:hover:bg-slate-700 dark:text-slate-300 rounded-xl font-semibold transition text-sm cursor-pointer" %>
  </div>
<% end %>
